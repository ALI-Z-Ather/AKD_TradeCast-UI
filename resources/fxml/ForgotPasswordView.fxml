<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tradecast.controllers.ForgotPasswordController"
            prefWidth="400">
    <top>
        <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="8">
            <padding>
                <Insets top="4" right="8" bottom="4" left="8"/>
            </padding>
            <Label text="Forgot Password"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="panel" spacing="8">
            <padding>
                <Insets top="10" right="14" bottom="10" left="14"/>
            </padding>
            <Label text="Enter your User ID and registered email. You will receive reset instructions (mock)."/>
            <Label text="User ID" style="-fx-font-weight: bold;"/>
            <TextField fx:id="userIdField" promptText="User ID"/>
            <Label text="Email Address" style="-fx-font-weight: bold;"/>
            <TextField fx:id="emailField" promptText="name@example.com"/>
            <Label fx:id="errorLabel" styleClass="label-error" wrapText="true" managed="false" visible="false"/>
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="OK" defaultButton="true" styleClass="button-default" onAction="#onOk"/>
                <Button text="Cancel" cancelButton="true" onAction="#onCancel"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
