<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tradecast.controllers.PortfolioWatchController"
            styleClass="profile-tab-root">
    <top>
        <VBox spacing="6" styleClass="portfolio-summary-strip">
            <padding>
                <Insets top="6" right="8" bottom="6" left="8"/>
            </padding>
            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="inset-panel">
                <padding>
                    <Insets top="6" right="8" bottom="6" left="8"/>
                </padding>
                <VBox spacing="2">
                    <Label text="Portfolio Worth" styleClass="summary-caption"/>
                    <TextField fx:id="portfolioWorthField" styleClass="summary-field" editable="false"
                               focusTraversable="false" prefColumnCount="12"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Ledger Balance" styleClass="summary-caption"/>
                    <TextField fx:id="ledgerBalanceField" styleClass="summary-field" editable="false"
                               focusTraversable="false" prefColumnCount="12"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Sold Collaterals" styleClass="summary-caption"/>
                    <TextField fx:id="soldCollateralsField" styleClass="summary-field" editable="false"
                               focusTraversable="false" prefColumnCount="12"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Net Worth" styleClass="summary-caption"/>
                    <TextField fx:id="netWorthField" styleClass="summary-field" editable="false"
                               focusTraversable="false" prefColumnCount="12"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Liquidate All Security Holdings" onAction="#onLiquidateAll"
                        styleClass="button-toolbar"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>
    <center>
        <TableView fx:id="holdingsTable" styleClass="market-table portfolio-table"/>
    </center>
</BorderPane>
